# Local development — MinIO on localhost:9000 replaces AWS S3.
#
# This is the SINGLE SOURCE OF TRUTH for local credentials and paths.
# Both the plugin and minio-init read from this file.
#
# Two credential profiles:
#   CC_*   — Cloud Compute SDK (reads payload, manages orchestration)
#   FFRD_* — StormHub data store. "FFRD" = Future Flood Risk Data (USACE program).

# --- MinIO ---
MINIO_ROOT_USER=ccuser
MINIO_ROOT_PASSWORD=ccpassword

# --- Cloud Compute SDK (CC profile) ---
CC_MANIFEST_ID=manifest_id
CC_ROOT=stormhub
CC_PAYLOAD_ID=1001
CC_AWS_S3_BUCKET=cc-store
CC_AWS_DEFAULT_REGION=us-east-1
CC_AWS_ENDPOINT=http://localhost:9000
CC_AWS_ACCESS_KEY_ID=ccaccesskey
CC_AWS_SECRET_ACCESS_KEY=ccsecretkey

# --- StormHub Data Store (FFRD profile) ---
FFRD_AWS_S3_BUCKET=stormhub-data
FFRD_AWS_DEFAULT_REGION=us-east-1
FFRD_AWS_ENDPOINT=http://localhost:9000
FFRD_AWS_ACCESS_KEY_ID=ffrdaccesskey
FFRD_AWS_SECRET_ACCESS_KEY=ffrdsecretkey

# --- Paths for MinIO seeding (must match payloads in test/examples/) ---
FFRD_STORE_ROOT=model-library/ffrd-trinity
FFRD_INPUT_PATH=conformance/storm-catalog
